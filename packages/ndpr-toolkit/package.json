    "build": "tsup && pnpm build:types",
    "build:types": "tsc -p tsconfig.lib.json",
    "dev": "tsup --watch",
    "test": "jest",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "sync:changelog": "node -e \"require('node:fs').copyFileSync('../../CHANGELOG.md','./CHANGELOG.md')\"",
    "sync:readme": "node -e \"require('node:fs').copyFileSync('../../README.md','./README.md')\"",
    "prepublishOnly": "pnpm sync:changelog && pnpm sync:readme && pnpm build"
