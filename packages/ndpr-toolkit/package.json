{
  "name": "@tantainnovative/ndpr-toolkit",
  "version": "1.0.7",
  "description": "A comprehensive toolkit for implementing NDPR-compliant features in web applications",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.mjs",
      "require": "./dist/core.js"
    },
    "./hooks": {
      "types": "./dist/hooks-entry.d.ts",
      "import": "./dist/hooks-entry.mjs",
      "require": "./dist/hooks-entry.js"
    },
    "./consent": {
      "types": "./dist/consent.d.ts",
      "import": "./dist/consent.mjs",
      "require": "./dist/consent.js"
    },
    "./dsr": {
      "types": "./dist/dsr.d.ts",
      "import": "./dist/dsr.mjs",
      "require": "./dist/dsr.js"
    },
    "./dpia": {
      "types": "./dist/dpia.d.ts",
      "import": "./dist/dpia.mjs",
      "require": "./dist/dpia.js"
    },
    "./breach": {
      "types": "./dist/breach.d.ts",
      "import": "./dist/breach.mjs",
      "require": "./dist/breach.js"
    },
    "./policy": {
      "types": "./dist/policy.d.ts",
      "import": "./dist/policy.mjs",
      "require": "./dist/policy.js"
    },
    "./lawful-basis": {
      "types": "./dist/lawful-basis-entry.d.ts",
      "import": "./dist/lawful-basis-entry.mjs",
      "require": "./dist/lawful-basis-entry.js"
    },
    "./cross-border": {
      "types": "./dist/cross-border-entry.d.ts",
      "import": "./dist/cross-border-entry.mjs",
      "require": "./dist/cross-border-entry.js"
    },
    "./ropa": {
      "types": "./dist/ropa-entry.d.ts",
      "import": "./dist/ropa-entry.mjs",
      "require": "./dist/ropa-entry.js"
    },
    "./adapters": {
      "types": "./dist/adapters.d.ts",
      "import": "./dist/adapters.mjs",
      "require": "./dist/adapters.js"
    },
    "./unstyled": {
      "types": "./dist/unstyled.d.ts",
      "import": "./dist/unstyled.mjs",
      "require": "./dist/unstyled.js"
    },
    "./presets": {
      "types": "./dist/presets-entry.d.ts",
      "import": "./dist/presets.mjs",
      "require": "./dist/presets.js"
    },
    "./styles": {
      "import": "./dist/styles.css",
      "require": "./dist/styles.css"
    }
  },
  "typesVersions": {
    "*": {
      "core": ["./dist/core.d.ts"],
      "hooks": ["./dist/hooks-entry.d.ts"],
      "consent": ["./dist/consent.d.ts"],
      "dsr": ["./dist/dsr.d.ts"],
      "dpia": ["./dist/dpia.d.ts"],
      "breach": ["./dist/breach.d.ts"],
      "policy": ["./dist/policy.d.ts"],
      "lawful-basis": ["./dist/lawful-basis-entry.d.ts"],
      "cross-border": ["./dist/cross-border-entry.d.ts"],
      "ropa": ["./dist/ropa-entry.d.ts"],
      "adapters": ["./dist/adapters.d.ts"],
      "presets": ["./dist/presets-entry.d.ts"]
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup && pnpm build:types",
    "build:types": "tsc -p tsconfig.lib.json",
    "dev": "tsup --watch",
    "test": "jest",
    "lint": "eslint src --ext .ts,.tsx",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "ndpr",
    "data-protection",
    "privacy",
    "compliance",
    "nigeria",
    "consent",
    "dpia",
    "data-subject-rights",
    "breach-notification"
  ],
  "author": "Tanta Innovative",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tantainnovative/ndpr-toolkit"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^29.5.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react": "^7.30.0",
    "eslint-plugin-react-hooks": "^4.5.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.5.0",
    "jest-environment-jsdom": "^29.5.0",
    "react-test-renderer": "^18.2.0",
    "ts-jest": "^29.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "tslib": "^2.4.0"
  }
}
