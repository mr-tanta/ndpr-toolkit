{
  "name": "@tantainnovative/ndpr-toolkit",
  "version": "2.1.0",
  "private": false,
  "description": "Nigeria Data Protection Toolkit — enterprise-grade compliance components for the Nigeria Data Protection Act (NDPA) 2023",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build && node scripts/post-build.js",
    "build:lib": "tsup",
    "prepublishOnly": "pnpm build:lib",
    "start": "next start",
    "lint": "next lint",
    "test": "jest --passWithNoTests",
    "export": "next export",
    "build:static": "next build",
    "deploy": "next build && touch out/.nojekyll && gh-pages -d out",
    "release": "standard-version",
    "release:minor": "standard-version --release-as minor",
    "release:major": "standard-version --release-as major",
    "release:patch": "standard-version --release-as patch"
  },
  "keywords": [
    "ndpa",
    "ndpr",
    "nigeria",
    "data-protection",
    "compliance",
    "privacy",
    "ndpc",
    "consent",
    "dpia",
    "data-subject-rights",
    "breach-notification",
    "cross-border-transfer",
    "ropa",
    "lawful-basis"
  ],
  "author": {
    "name": "Abraham Esandayinze Tanta",
    "url": "https://github.com/mr-tanta"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tantainnovative/ndpr-toolkit.git"
  },
  "bugs": {
    "url": "https://github.com/tantainnovative/ndpr-toolkit/issues"
  },
  "homepage": "https://github.com/tantainnovative/ndpr-toolkit#readme",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.mjs",
      "require": "./dist/core.js"
    },
    "./hooks": {
      "types": "./dist/hooks.d.ts",
      "import": "./dist/hooks.mjs",
      "require": "./dist/hooks.js"
    },
    "./consent": {
      "types": "./dist/consent.d.ts",
      "import": "./dist/consent.mjs",
      "require": "./dist/consent.js"
    },
    "./dsr": {
      "types": "./dist/dsr.d.ts",
      "import": "./dist/dsr.mjs",
      "require": "./dist/dsr.js"
    },
    "./dpia": {
      "types": "./dist/dpia.d.ts",
      "import": "./dist/dpia.mjs",
      "require": "./dist/dpia.js"
    },
    "./breach": {
      "types": "./dist/breach.d.ts",
      "import": "./dist/breach.mjs",
      "require": "./dist/breach.js"
    },
    "./policy": {
      "types": "./dist/policy.d.ts",
      "import": "./dist/policy.mjs",
      "require": "./dist/policy.js"
    },
    "./lawful-basis": {
      "types": "./dist/lawful-basis.d.ts",
      "import": "./dist/lawful-basis.mjs",
      "require": "./dist/lawful-basis.js"
    },
    "./cross-border": {
      "types": "./dist/cross-border.d.ts",
      "import": "./dist/cross-border.mjs",
      "require": "./dist/cross-border.js"
    },
    "./ropa": {
      "types": "./dist/ropa.d.ts",
      "import": "./dist/ropa.mjs",
      "require": "./dist/ropa.js"
    },
    "./unstyled": {
      "types": "./dist/unstyled.d.ts",
      "import": "./dist/unstyled.mjs",
      "require": "./dist/unstyled.js"
    },
    "./styles": "./dist/styles.css"
  },
  "typesVersions": {
    "*": {
      "core": ["./dist/core.d.ts"],
      "hooks": ["./dist/hooks.d.ts"],
      "consent": ["./dist/consent.d.ts"],
      "dsr": ["./dist/dsr.d.ts"],
      "dpia": ["./dist/dpia.d.ts"],
      "breach": ["./dist/breach.d.ts"],
      "policy": ["./dist/policy.d.ts"],
      "lawful-basis": ["./dist/lawful-basis.d.ts"],
      "cross-border": ["./dist/cross-border.d.ts"],
      "ropa": ["./dist/ropa.d.ts"],
      "unstyled": ["./dist/unstyled.d.ts"]
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "tslib": "^2.4.0",
    "uuid": "^13.0.0"
  },
  "peerDependencies": {
    "react": "^16.8.0 || ^17.0.0 || ^18.0.0 || ^19.0.0",
    "react-dom": "^16.8.0 || ^17.0.0 || ^18.0.0 || ^19.0.0",
    "@radix-ui/react-label": "^2.1.4",
    "@radix-ui/react-slot": "^1.2.0",
    "@radix-ui/react-switch": "^1.2.2",
    "@radix-ui/react-tabs": "^1.1.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jspdf": "^3.0.3",
    "lucide-react": "^0.507.0",
    "tailwind-merge": "^2.6.0"
  },
  "peerDependenciesMeta": {
    "@radix-ui/react-label": { "optional": true },
    "@radix-ui/react-slot": { "optional": true },
    "@radix-ui/react-switch": { "optional": true },
    "@radix-ui/react-tabs": { "optional": true },
    "class-variance-authority": { "optional": true },
    "clsx": { "optional": true },
    "jspdf": { "optional": true },
    "lucide-react": { "optional": true },
    "tailwind-merge": { "optional": true }
  },
  "devDependencies": {
    "@next/font": "^14.2.15",
    "@tailwindcss/postcss": "^4.1.13",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/jest": "^29.5.0",
    "@types/react": "^19.1.15",
    "@types/react-dom": "^19.1.9",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.0.0",
    "eslint-plugin-react": "^7.30.0",
    "eslint-plugin-react-hooks": "^4.5.0",
    "gh-pages": "^6.3.0",
    "husky": "^9.1.7",
    "posthog-js": "^1.268.8",
    "posthog-node": "^5.9.2",
    "jest": "^29.5.0",
    "jest-environment-jsdom": "^30.2.0",
    "lint-staged": "^16.2.3",
    "next": "^15.5.4",
    "postcss": "^8.5.6",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-test-renderer": "^18.2.0",
    "standard-version": "^9.5.0",
    "tailwindcss": "^4.1.13",
    "ts-jest": "^29.0.0",
    "tsup": "^8.5.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.0.0"
  }
}
